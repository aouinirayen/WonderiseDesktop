<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.UpdateExperienceController"
      stylesheets="@../styles/responsive.css"
      styleClass="main-container">

    <!-- En-tête de l'interface -->
    <top>
        <VBox styleClass="header">
            <Label fx:id="headerTitle" text="Modifier l'Expérience" styleClass="header-title"/>
        </VBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox styleClass="form-container" spacing="15">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                
                <VBox styleClass="form-field">
                    <Label text="Titre" styleClass="form-label"/>
                    <TextField fx:id="titreField" promptText="Entrez le titre"/>
                </VBox>

                <VBox styleClass="form-field">
                    <Label text="Description" styleClass="form-label"/>
                    <TextArea fx:id="descriptionArea" promptText="Entrez la description" wrapText="true" prefRowCount="3"/>
                </VBox>

                <VBox styleClass="form-field">
                    <Label text="Image" styleClass="form-label"/>
                    <HBox spacing="10">
                        <TextField fx:id="imageField" promptText="Entrez l'URL de l'image" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="previewButton" text="Prévisualiser" onAction="#previewImage" styleClass="button"/>
                    </HBox>
                </VBox>
                
                <VBox styleClass="form-field">
                    <Label text="Aperçu de l'image" styleClass="form-label"/>
                    <ImageView fx:id="imagePreview" fitWidth="300" fitHeight="200" preserveRatio="true" styleClass="image-preview"/>
                </VBox>

                <VBox styleClass="form-field">
                    <Label text="Lieu" styleClass="form-label"/>
                    <TextField fx:id="lieuField" promptText="Entrez le lieu"/>
                </VBox>

                <VBox styleClass="form-field">
                    <Label text="Catégorie" styleClass="form-label"/>
                    <ComboBox fx:id="categorieField" promptText="Sélectionnez une catégorie" prefWidth="300"/>
                </VBox>

                <VBox styleClass="form-field">
                    <Label text="ID Client" styleClass="form-label"/>
                    <TextField fx:id="idClientField" promptText="Entrez l'ID client"/>
                </VBox>

                <VBox styleClass="form-field">
                    <Label text="Date" styleClass="form-label"/>
                    <DatePicker fx:id="datePicker" promptText="Sélectionnez une date"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    
    <!-- Barre de navigation/boutons en bas -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="footer">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Button fx:id="backButton" text="Retour" styleClass="button" onAction="#handleBack"/>
            <Button text="Annuler" onAction="#handleCancel" styleClass="button"/>
            <Button text="Mettre à jour" onAction="#handleUpdate" styleClass="success-button"/>
        </HBox>
    </bottom>
</BorderPane>
