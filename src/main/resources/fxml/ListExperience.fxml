<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.*?>

<BorderPane fx:id="mainContainer" xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ListExperienceController"
            stylesheets="@../styles/list-experience.css">

    <!-- Header Section -->
    <top>
        <VBox styleClass="header" alignment="CENTER_LEFT">
            <padding>
                <Insets left="20" right="20" top="15" bottom="15"/>
            </padding>
            <Label fx:id="headerTitle" text="Liste des Expériences" styleClass="header-title">
                <font>
                    <Font size="24" weight="BOLD"/>
                </font>
            </Label>
        </VBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <VBox spacing="20" styleClass="main-content">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10"/>
            </padding>

            <!-- Search and Action Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="search-container">
                <TextField fx:id="searchField"
                           promptText="Rechercher des expériences..."
                           styleClass="search-field"
                           HBox.hgrow="ALWAYS">
                    <tooltip>
                        <Tooltip text="Rechercher par titre, lieu ou catégorie"/>
                    </tooltip>
                </TextField>

                <Button onAction="#handleAddExperience"
                        styleClass="success-button"
                        text="Ajouter une expérience">
                    <graphic>
                        <ImageView>
                            <Image url="@../icons/add.png" requestedWidth="16" requestedHeight="16"/>
                        </ImageView>
                    </graphic>
                    <tooltip>
                        <Tooltip text="Ajouter une nouvelle expérience"/>
                    </tooltip>
                </Button>
            </HBox>

            <!-- Experiences List Container with improved responsiveness -->
            <ScrollPane fitToWidth="true" styleClass="list-view" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="experiencesContainer"
                          hgap="20"
                          vgap="20"
                          prefWrapLength="1200"
                          alignment="TOP_CENTER"
                          styleClass="experiences-flow-container">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20"/>
                    </padding>
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>

    <!-- Footer Section -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="footer">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Label fx:id="experienceCountLabel" styleClass="count-label" text="0 expériences"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="refreshButton"
                    text="Rafraîchir"
                    onAction="#loadExperiences"
                    styleClass="button">
                <graphic>
                    <ImageView>
                        <Image url="@../icons/refresh.png" requestedWidth="16" requestedHeight="16"/>
                    </ImageView>
                </graphic>
                <tooltip>
                    <Tooltip text="Recharger la liste des expériences"/>
                </tooltip>
            </Button>
        </HBox>
    </bottom>
</BorderPane>