<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="732.0" prefWidth="867.0" spacing="20" stylesheets="@../styles/add-experience.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AddExperienceController">

    <VBox prefHeight="91.0" prefWidth="869.0" styleClass="header">
        <Label styleClass="header-title" text="Ajouter une Expérience" />
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="15" styleClass="form-container">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <VBox styleClass="form-field">
                <Label styleClass="form-label" text="Titre" />
                <TextField fx:id="titreField" promptText="Entrez le titre" />
            </VBox>

            <VBox styleClass="form-field">
                <Label styleClass="form-label" text="Description" />
                <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Entrez la description" wrapText="true" />
            </VBox>

            <VBox styleClass="form-field">
                <Label styleClass="form-label" text="Image" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="imagePathField" promptText="Aucun fichier sélectionné" editable="false" HBox.hgrow="ALWAYS" />
                    <Button fx:id="browseButton" text="Parcourir..." onAction="#handleBrowseImage" styleClass="button" />
                </HBox>
                <VBox styleClass="image-preview-container" alignment="CENTER">
                    <padding>
                        <Insets top="10" />
                    </padding>
                    <ImageView fx:id="imagePreview" fitWidth="300" fitHeight="200" preserveRatio="true" styleClass="image-preview" />
                </VBox>
            </VBox>

            <VBox styleClass="form-field">
                <Label styleClass="form-label" text="Lieu" />
                <TextField fx:id="lieuField" promptText="Entrez le lieu" />
            </VBox>

            <VBox styleClass="form-field">
                <Label styleClass="form-label" text="Catégorie" />
                <ComboBox fx:id="categorieField" promptText="Sélectionnez une catégorie" prefWidth="300" />
            </VBox>

            <VBox styleClass="form-field">
                <Label styleClass="form-label" text="ID Client" />
                <TextField fx:id="idClientField" promptText="Entrez l'ID client" />
            </VBox>

            <VBox styleClass="form-field">
                <Label styleClass="form-label" text="Date" />
                <DatePicker fx:id="datePicker" promptText="Sélectionnez une date" />
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleCancel" styleClass="button" text="Annuler" />
                <Button onAction="#handleAdd" styleClass="button,success" text="Ajouter" />
            </HBox>
            
            <HBox alignment="CENTER" spacing="10" styleClass="navigation-buttons">
                <padding>
                    <Insets top="20" />
                </padding>
                <Button fx:id="goToListButton" text="Voir la liste des expériences" onAction="#goToExperienceList" styleClass="button" />
                <Button fx:id="goToDetailsButton" text="Voir les détails d'expérience" onAction="#goToExperienceDetails" styleClass="button" />
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
