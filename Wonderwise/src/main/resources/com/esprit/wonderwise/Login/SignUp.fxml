<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esprit.wonderwise.Controller.Login.SignUpController">
    <StackPane fx:id="rootPane" prefHeight="700.0" prefWidth="800.0" style="-fx-background-color: linear-gradient(to right bottom, #1a237e, #0d47a1);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        
        <!-- SignUp Card -->
        <VBox alignment="CENTER" maxWidth="450" spacing="20" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 0);">
            <!-- Logo -->
            <ImageView fitHeight="70" fitWidth="70" preserveRatio="true">
                <image>
                    <Image url="@../icons/gps.png"/>
                </image>
            </ImageView>
            
            <!-- Title -->
            <VBox alignment="CENTER" spacing="5">
                <Label text="Create Account" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>
                <Text style="-fx-fill: #757575; -fx-font-size: 14px;" text="Start your journey with us"/>
            </VBox>
            
            <!-- Form -->
            <VBox spacing="15" style="-fx-padding: 20 0;">
                <HBox spacing="10">
                    <TextField fx:id="firstNameField" promptText="First Name" 
                             style="-fx-background-color: #f5f5f5; 
                                    -fx-background-radius: 5;
                                    -fx-border-color: transparent;
                                    -fx-padding: 12;
                                    -fx-font-size: 14px;"
                             HBox.hgrow="ALWAYS"/>
                             
                    <TextField fx:id="lastNameField" promptText="Last Name"
                             style="-fx-background-color: #f5f5f5;
                                    -fx-background-radius: 5;
                                    -fx-border-color: transparent;
                                    -fx-padding: 12;
                                    -fx-font-size: 14px;"
                             HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <TextField fx:id="emailField" promptText="Email" 
                         style="-fx-background-color: #f5f5f5; 
                                -fx-background-radius: 5;
                                -fx-border-color: transparent;
                                -fx-padding: 12;
                                -fx-font-size: 14px;"/>
                                
                <TextField fx:id="usernameField" promptText="Username" 
                         style="-fx-background-color: #f5f5f5; 
                                -fx-background-radius: 5;
                                -fx-border-color: transparent;
                                -fx-padding: 12;
                                -fx-font-size: 14px;"/>
                
                <PasswordField fx:id="passwordField" promptText="Password"
                             style="-fx-background-color: #f5f5f5;
                                    -fx-background-radius: 5;
                                    -fx-border-color: transparent;
                                    -fx-padding: 12;
                                    -fx-font-size: 14px;"/>
                                    
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"
                             style="-fx-background-color: #f5f5f5;
                                    -fx-background-radius: 5;
                                    -fx-border-color: transparent;
                                    -fx-padding: 12;
                                    -fx-font-size: 14px;"/>
            </VBox>
            
            <!-- Terms -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <CheckBox fx:id="termsCheckBox" style="-fx-text-fill: #757575;"/>
                <Text style="-fx-fill: #757575;" text="I agree to the "/>
                <Hyperlink style="-fx-text-fill: #2196F3; -fx-underline: true;" text="Terms and Conditions"/>
            </HBox>
            
            <!-- Sign Up Button -->
            <Button fx:id="signUpButton" text="Create Account" 
                    style="-fx-background-color: #2196F3;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 5;
                           -fx-min-width: 370;
                           -fx-padding: 14;
                           -fx-font-size: 14px;
                           -fx-cursor: hand;"/>
            
            <!-- Login Link -->
            <HBox alignment="CENTER" spacing="5">
                <Text style="-fx-fill: #757575;" text="Already have an account?"/>
                <Hyperlink fx:id="loginLink" text="Sign In"
                          style="-fx-text-fill: #2196F3;
                                 -fx-underline: false;
                                 -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </StackPane>
</AnchorPane>